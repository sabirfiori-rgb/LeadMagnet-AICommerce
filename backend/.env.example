# Server
NODE_ENV=development
PORT=5000
API_URL=http://localhost:5000

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/kinetiq_dev

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Session
SESSION_SECRET=your-super-secret-session-key-change-in-production
SESSION_COOKIE_DOMAIN=localhost
SESSION_COOKIE_SECURE=false

# Email
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=noreply@kinetiq.app

# Frontend
FRONTEND_URL=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGIN=http://localhost:5173

# Password Reset
PASSWORD_RESET_EXPIRES_IN=1h

# Email Verification
EMAIL_VERIFICATION_EXPIRES_IN=24h

# External providers
# SMTP_* aliases are also supported, but the EMAIL_* settings above are the
# default configuration used by this example.
EMAIL_REPLY_TO=reply@example.com

# Twilio SMS
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+15551234567
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_API_BASE_URL=https://api.twilio.com

# WhatsApp (Twilio sandbox or approved sender, for example whatsapp:+14155238886)
WHATSAPP_PROVIDER=twilio
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Stripe card payments
STRIPE_SECRET_KEY=sk-placeholder-replace-in-production
STRIPE_PUBLISHABLE_KEY=pk-placeholder-replace-in-production
STRIPE_WEBHOOK_SECRET=whsec-placeholder-replace-in-production

# Optional fallback for provider callbacks without native signatures
PROVIDER_WEBHOOK_SECRET=replace-with-a-long-random-secret
