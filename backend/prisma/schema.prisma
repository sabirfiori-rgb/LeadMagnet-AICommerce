// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User Account
model User {
  id                    String   @id @default(cuid())
  email                 String   @unique
  firstName             String?
  lastName              String?
  passwordHash          String
  isEmailVerified       Boolean  @default(false)
  profileImage          String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  deletedAt             DateTime?

  // Relations
  organizationMembers   OrganizationMember[]
  workspaceMembers      WorkspaceMember[]
  sessions              Session[]
  passwordResetTokens   PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  auditLogs             AuditLog[]
  assignedContacts      Contact[]
  assignedOpportunities Opportunity[]
  assignedConversations Conversation[] @relation("AssignedConversation")
  createdWorkflows      Workflow[] @relation("WorkflowCreatedBy")
  triggeredWorkflowExecutions WorkflowExecution[] @relation("WorkflowTriggeredBy")
  createdEmailTemplates EmailTemplate[] @relation("EmailTemplateCreatedBy")
  createdSmsTemplates   SmsTemplate[] @relation("SmsTemplateCreatedBy")
  createdEmailCampaigns EmailCampaign[] @relation("EmailCampaignCreatedBy")
  createdOutboundMessages OutboundMessage[] @relation("OutboundMessageCreatedBy")

  @@index([email])
  @@index([createdAt])
}

// Organization (Company/Account)
model Organization {
  id                    String   @id @default(cuid())
  name                  String
  slug                  String   @unique
  description           String?
  logo                  String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  deletedAt             DateTime?

  // Relations
  members               OrganizationMember[]
  workspaces            Workspace[]
  auditLogs             AuditLog[]

  @@index([slug])
  @@index([createdAt])
}

// Organization Membership
model OrganizationMember {
  id                    String   @id @default(cuid())
  userId                String
  organizationId        String
  role                  String   @default("member") // owner, admin, member
  joinedAt              DateTime @default(now())
  invitedAt             DateTime?
  invitedBy             String?

  // Relations
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization          Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@index([userId])
}

// Workspace (Project/Workspace within an Organization)
model Workspace {
  id                    String   @id @default(cuid())
  organizationId        String
  name                  String
  slug                  String
  description           String?
  icon                  String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  deletedAt             DateTime?

  // Relations
  organization          Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members               WorkspaceMember[]
  auditLogs             AuditLog[]
  contacts              Contact[]
  companies             Company[]
  tags                  Tag[]
  customFields          CustomField[]
  pipelines             Pipeline[]
  opportunities         Opportunity[]
  contactActivities     ContactActivity[]
  tasks                 Task[]
  channels              Channel[]
  conversations         Conversation[]
  workflows             Workflow[]
  workflowExecutions    WorkflowExecution[]
  workflowExecutionLogs WorkflowExecutionLog[]
  emailTemplates        EmailTemplate[]
  smsTemplates          SmsTemplate[]
  emailCampaigns        EmailCampaign[]
  outboundMessages      OutboundMessage[]
  outboundMessageLogs   OutboundMessageLog[]
  messageTrackingLinks  MessageTrackingLink[]
  messageTrackingEvents MessageTrackingEvent[]
  communicationOptOuts  CommunicationOptOut[]
  funnels               Funnel[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@index([createdAt])
}

// Workspace Membership
model WorkspaceMember {
  id                    String   @id @default(cuid())
  userId                String
  workspaceId           String
  role                  String   @default("member") // owner, admin, editor, viewer
  joinedAt              DateTime @default(now())
  invitedAt             DateTime?
  invitedBy             String?

  // Relations
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace             Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([workspaceId])
  @@index([userId])
}

// Session
model Session {
  id                    String   @id @default(cuid())
  userId                String
  token                 String   @unique
  ipAddress             String?
  userAgent             String?
  expiresAt             DateTime
  createdAt             DateTime @default(now())
  revokedAt             DateTime?

  // Relations
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

// Password Reset Token
model PasswordResetToken {
  id                    String   @id @default(cuid())
  userId                String
  token                 String   @unique
  expiresAt             DateTime
  usedAt                DateTime?
  createdAt             DateTime @default(now())

  // Relations
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

// Email Verification Token
model EmailVerificationToken {
  id                    String   @id @default(cuid())
  userId                String
  token                 String   @unique
  expiresAt             DateTime
  verifiedAt            DateTime?
  createdAt             DateTime @default(now())

  // Relations
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

// Audit Log
model AuditLog {
  id                    String   @id @default(cuid())
  userId                String
  organizationId        String?
  workspaceId           String?
  action                String   // created, updated, deleted, accessed
  resource              String   // user, organization, workspace, member, contact, etc
  resourceId            String?
  changes               Json?    // Store what changed
  ipAddress             String?
  userAgent             String?
  createdAt             DateTime @default(now())

  // Relations
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization          Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  workspace             Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([organizationId])
  @@index([workspaceId])
  @@index([createdAt])
  @@index([action])
  @@index([resource])
}

// Role (For future permissions system)
model Role {
  id                    String   @id @default(cuid())
  name                  String   @unique
  description           String?
  permissions           String[] // Array of permission strings
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

// ============= CRM MODELS =============

// Contact
model Contact {
  id                    String   @id @default(cuid())
  workspaceId           String
  firstName             String
  lastName              String
  email                 String?
  phone                 String?
  companyId             String?
  jobTitle              String?
  address               String?
  source                String?
  notes                 String?
  assignedUserId        String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  deletedAt             DateTime?

  // Relations
  workspace             Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  company               Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  assignedUser          User? @relation(fields: [assignedUserId], references: [id], onDelete: SetNull)
  tags                  ContactTag[]
  customFieldValues     CustomFieldValue[]
  activities            ContactActivity[]
  opportunities         Opportunity[]
  conversations         Conversation[]
  workflowExecutions    WorkflowExecution[]
  outboundMessages      OutboundMessage[]
  communicationOptOuts  CommunicationOptOut[]

  @@index([workspaceId])
  @@index([email])
  @@index([assignedUserId])
  @@index([createdAt])
}

// Company
model Company {
  id                    String   @id @default(cuid())
  workspaceId           String
  name                  String
  website               String?
  phone                 String?
  address               String?
  industry              String?
  employeeCount         String?
  description           String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  deletedAt             DateTime?

  // Relations
  workspace             Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contacts              Contact[]

  @@index([workspaceId])
  @@index([createdAt])
}

// Tag
model Tag {
  id                    String   @id @default(cuid())
  workspaceId           String
  name                  String
  color                 String   @default("#3B82F6")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Relations
  workspace             Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contacts              ContactTag[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
}

// Contact Tag (Junction Table)
model ContactTag {
  id                    String   @id @default(cuid())
  contactId             String
  tagId                 String
  createdAt             DateTime @default(now())

  // Relations
  contact               Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tag                   Tag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([contactId, tagId])
  @@index([contactId])
  @@index([tagId])
}

// Custom Field
model CustomField {
  id                    String   @id @default(cuid())
  workspaceId           String
  name                  String
  fieldType             String   // text, number, date, dropdown, checkbox, phone, email
  options               String[] @default([]) // For dropdown fields
  isRequired            Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Relations
  workspace             Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  values                CustomFieldValue[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
}

// Custom Field Value
model CustomFieldValue {
  id                    String   @id @default(cuid())
  contactId             String
  customFieldId         String
  value                 String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Relations
  contact               Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  customField           CustomField @relation(fields: [customFieldId], references: [id], onDelete: Cascade)

  @@unique([contactId, customFieldId])
  @@index([contactId])
  @@index([customFieldId])
}

// Pipeline
model Pipeline {
  id                    String   @id @default(cuid())
  workspaceId           String
  name                  String
  description           String?
  isDefault             Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  deletedAt             DateTime?

  // Relations
  workspace             Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  stages                PipelineStage[]
  opportunities         Opportunity[]

  @@index([workspaceId])
  @@index([createdAt])
}

// Pipeline Stage
model PipelineStage {
  id                    String   @id @default(cuid())
  pipelineId            String
  name                  String
  order                 Int
  color                 String   @default("#3B82F6")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Relations
  pipeline              Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  opportunities         Opportunity[]

  @@unique([pipelineId, name])
  @@index([pipelineId])
}

// Opportunity (Deal)
model Opportunity {
  id                    String   @id @default(cuid())
  workspaceId           String
  contactId             String
  pipelineId            String
  stageId               String
  assignedUserId        String?
  title                 String
  dealValue             Float?
  probability           Int      @default(0) // 0-100
  expectedCloseDate     DateTime?
  notes                 String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  closedAt              DateTime?
  deletedAt             DateTime?

  // Relations
  workspace             Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contact               Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  pipeline              Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  stage                 PipelineStage @relation(fields: [stageId], references: [id], onDelete: Cascade)
  assignedUser          User? @relation(fields: [assignedUserId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([contactId])
  @@index([pipelineId])
  @@index([stageId])
  @@index([assignedUserId])
  @@index([createdAt])
}

// Contact Activity (Timeline)
model ContactActivity {
  id                    String   @id @default(cuid())
  workspaceId           String
  contactId             String
  type                  String   // contact_created, contact_updated, note, task, email, sms, appointment, pipeline_change
  title                 String
  description           String?
  metadata              Json?    // Additional data based on activity type
  createdAt             DateTime @default(now())

  // Relations
  workspace             Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contact               Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([contactId])
  @@index([createdAt])
}

// Task
model Task {
  id                    String   @id @default(cuid())
  workspaceId           String
  contactId             String?
  title                 String
  description           String?
  dueDate               DateTime?
  completed             Boolean  @default(false)
  completedAt           DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Relations
  workspace             Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([dueDate])
  @@index([completed])
}

// ============= UNIFIED CONVERSATIONS =============
model Channel {
  id          String   @id @default(cuid())
  workspaceId String
  type        String   // email, sms, whatsapp, internal
  name        String
  config      Json?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace     Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  conversations Conversation[]
  messages      Message[]

  @@index([workspaceId])
  @@unique([workspaceId, name])
}

model Conversation {
  id             String   @id @default(cuid())
  workspaceId    String
  contactId      String
  channelId      String
  assignedUserId String?
  subject        String?
  status         String   @default("open") // open, closed, archived
  lastMessageAt  DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  workspace          Workspace                @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contact            Contact                  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  channel            Channel                  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  assignedUser       User?                    @relation("AssignedConversation", fields: [assignedUserId], references: [id], onDelete: SetNull)
  participants       ConversationParticipant[]
  messages           Message[]
  assignmentHistory  ConversationAssignment[]
  outboundMessages   OutboundMessage[]

  @@index([workspaceId])
  @@index([contactId])
  @@index([assignedUserId])
  @@index([status])
  @@index([lastMessageAt])
}

model ConversationParticipant {
  id             String   @id @default(cuid())
  conversationId String
  userId         String
  lastReadAt     DateTime?
  unreadCount    Int      @default(0)
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  channelId      String
  senderUserId   String?
  direction      String   // inbound, outbound, internal
  type           String   @default("text") // text, internal_note
  body           String
  deliveryStatus String   @default("sent") // queued, sent, delivered, failed
  readAt         DateTime?
  createdAt      DateTime @default(now())

  conversation Conversation       @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  channel      Channel            @relation(fields: [channelId], references: [id], onDelete: Cascade)
  attachments  MessageAttachment[]

  @@index([conversationId])
  @@index([createdAt])
}

model MessageAttachment {
  id          String   @id @default(cuid())
  messageId   String
  fileName    String
  mimeType    String
  url         String
  size        Int?
  createdAt   DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
}

model ConversationAssignment {
  id               String   @id @default(cuid())
  conversationId   String
  assignedToUserId String?
  assignedByUserId String?
  createdAt        DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([assignedToUserId])
}

// ============= VISUAL WORKFLOW AUTOMATION =============

// A workflow belongs to one workspace and is composed as a directed graph of
// nodes and edges. Trigger/action-specific configuration deliberately remains
// JSON so new providers and automation types can be added without migrations.
model Workflow {
  id              String    @id @default(cuid())
  workspaceId     String
  name            String
  description     String?
  triggerType     String?
  triggerConfig   Json?
  status          String    @default("draft") // draft, active, inactive, archived
  isActive        Boolean   @default(false)
  version         Int       @default(1)
  createdByUserId String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  workspace       Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy       User?               @relation("WorkflowCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  nodes           WorkflowNode[]
  edges           WorkflowEdge[]
  executions      WorkflowExecution[]

  @@index([workspaceId])
  @@index([workspaceId, isActive])
  @@index([workspaceId, triggerType])
  @@index([createdByUserId])
  @@index([createdAt])
}

// A graph node. `type` is trigger, action, delay, condition, or branch; its
// type-specific payload (including provider details) is stored in `config`.
model WorkflowNode {
  id          String   @id @default(cuid())
  workflowId  String
  type        String
  label       String?
  config      Json?
  positionX   Float    @default(0)
  positionY   Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workflow       Workflow               @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  outgoingEdges  WorkflowEdge[]         @relation("WorkflowEdgeSource")
  incomingEdges  WorkflowEdge[]         @relation("WorkflowEdgeTarget")
  executionLogs  WorkflowExecutionLog[]

  @@index([workflowId])
  @@index([workflowId, type])
}

// Directed connection between nodes. Handles make condition/branch outcomes
// explicit while allowing the graph editor to stay provider-agnostic.
model WorkflowEdge {
  id             String   @id @default(cuid())
  workflowId     String
  sourceNodeId   String
  targetNodeId   String
  sourceHandle   String   @default("default")
  targetHandle   String   @default("default")
  config         Json?
  createdAt      DateTime @default(now())

  workflow       Workflow     @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  sourceNode     WorkflowNode @relation("WorkflowEdgeSource", fields: [sourceNodeId], references: [id], onDelete: Cascade)
  targetNode     WorkflowNode @relation("WorkflowEdgeTarget", fields: [targetNodeId], references: [id], onDelete: Cascade)

  @@unique([workflowId, sourceNodeId, targetNodeId, sourceHandle, targetHandle])
  @@index([workflowId])
  @@index([sourceNodeId])
  @@index([targetNodeId])
}

// One durable, queue-ready run of a workflow. A non-null deduplication key is
// unique per workflow, preventing a source event from creating duplicate runs.
model WorkflowExecution {
  id                String   @id @default(cuid())
  workspaceId       String
  workflowId        String
  contactId         String?
  triggeredByUserId String?
  triggerType       String?
  payload           Json?
  context           Json?
  status            String   @default("queued") // queued, running, completed, failed, cancelled
  deduplicationKey  String?
  attempts          Int      @default(0)
  maxAttempts       Int      @default(3)
  scheduledFor      DateTime?
  nextRunAt         DateTime?
  startedAt         DateTime?
  completedAt       DateTime?
  error             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  workspace         Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workflow          Workflow              @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  contact           Contact?              @relation(fields: [contactId], references: [id], onDelete: SetNull)
  triggeredBy       User?                 @relation("WorkflowTriggeredBy", fields: [triggeredByUserId], references: [id], onDelete: SetNull)
  logs              WorkflowExecutionLog[]
  outboundMessages  OutboundMessage[]

  @@unique([workflowId, deduplicationKey])
  @@index([workspaceId])
  @@index([workflowId])
  @@index([contactId])
  @@index([triggeredByUserId])
  @@index([workspaceId, status])
  @@index([workflowId, status])
  @@index([status, nextRunAt])
  @@index([createdAt])
}

// Append-only audit trail for execution progress, retries, provider responses,
// and errors. It is directly workspace-scoped to support safe tenant queries.
model WorkflowExecutionLog {
  id                  String   @id @default(cuid())
  workspaceId         String
  executionId         String
  workflowNodeId      String?
  level               String   @default("info") // debug, info, warn, error
  event               String
  message             String?
  data                Json?
  attempt             Int      @default(0)
  createdAt           DateTime @default(now())

  workspace           Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  execution           WorkflowExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  workflowNode        WorkflowNode?     @relation(fields: [workflowNodeId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([executionId])
  @@index([workflowNodeId])
  @@index([workspaceId, createdAt])
  @@index([executionId, createdAt])
}

// ============= PHASE 6: WEBSITE BUILDER & SALES FUNNELS =============

// Funnel (Sales Funnel)
model Funnel {
  id                    String   @id @default(cuid())
  workspaceId           String
  name                  String
  description           String?
  slug                  String?
  status                String   @default("draft") // draft, published, archived
  isPublished           Boolean  @default(false)
  publishedUrl          String?
  customDomain          String?
  funnelType            String   @default("sales") // sales, landing, webinar, survey
  version               Int      @default(1)
  tags                  String[]
  settings              Json?    // Global funnel settings
  seoMeta               Json?    // SEO metadata
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  deletedAt             DateTime?

  // Relations
  workspace             Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  pages                 FunnelPage[]
  versions              FunnelVersion[]
  analytics             FunnelAnalytics[]
  forms                 FunnelForm[]
  formSubmissions       FunnelFormSubmission[]

  @@index([workspaceId])
  @@index([workspaceId, status])
  @@index([slug])
  @@index([createdAt])
}

// Funnel Page (Landing, Sales, Checkout, Thank You, Upsell, Downsell, Order Confirmation)
model FunnelPage {
  id                    String   @id @default(cuid())
  funnelId              String
  pageType              String   @default("landing") // landing, sales, checkout, thank_you, upsell, downsell, order_confirmation
  name                  String
  slug                  String?
  sortOrder             Int      @default(0)
  isHomePage            Boolean  @default(false)
  settings              Json?    // Page-level settings
  seoMeta               Json?    // Page SEO
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Relations
  funnel                Funnel         @relation(fields: [funnelId], references: [id], onDelete: Cascade)
  blocks                FunnelBlock[]

  @@index([funnelId])
  @@unique([funnelId, slug])
}

// Funnel Block (Visual Builder Blocks)
model FunnelBlock {
  id                    String   @id @default(cuid())
  pageId                String
  parentId              String?   // For nested blocks
  blockType             String   // section, container, columns, grid, heading, paragraph, image, gallery, button, video, form, countdown, testimonials, faq, pricing, features, team, navigation, footer, divider, spacer, progress_bar, icons, social_icons, maps, html_block, embed_block, popup, sticky_bar
  blockName             String?
  content               Json?    // Block content (text, images, videos, etc.)
  styles                Json?    // Styling (typography, colors, background, gradients, padding, margin, border, shadow, opacity, animation, hover)
  responsiveStyles      Json?    // { desktop: {}, tablet: {}, mobile: {} }
  animation             Json?    // Animation settings
  visibility            Json?    // Visibility conditions
  sortOrder             Float    @default(0)
  isHidden              Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Relations
  page                  FunnelPage       @relation(fields: [pageId], references: [id], onDelete: Cascade)
  children              FunnelBlock[]    @relation("FunnelBlockChildren")
  parent                FunnelBlock?     @relation("FunnelBlockChildren", fields: [parentId], references: [id], onDelete: SetNull)

  @@index([pageId])
  @@index([parentId])
}

// Funnel Version History
model FunnelVersion {
  id                    String   @id @default(cuid())
  funnelId              String
  version               Int
  snapshot              Json?    // Full snapshot of funnel data (pages, blocks, settings)
  createdByUserId       String?
  changelog             String?
  createdAt             DateTime @default(now())

  // Relations
  funnel                Funnel @relation(fields: [funnelId], references: [id], onDelete: Cascade)

  @@unique([funnelId, version])
  @@index([funnelId])
  @@index([createdAt])
}

// Funnel Form (Visual Form Builder)
model FunnelForm {
  id                    String   @id @default(cuid())
  funnelId              String
  name                  String
  fields                Json?    // Array of form fields
  settings              Json?    // Form settings (redirect URL, submission behavior)
  afterSubmission       Json?    // Post-submission actions
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Relations
  funnel                Funnel                @relation(fields: [funnelId], references: [id], onDelete: Cascade)
  submissions           FunnelFormSubmission[]

  @@index([funnelId])
}

// Funnel Form Submission
model FunnelFormSubmission {
  id                    String   @id @default(cuid())
  funnelId              String
  formId                String
  contactId             String?
  data                  Json?    // Submitted field values
  metadata              Json?    // Browser, IP, UTM params, etc.
  createdAt             DateTime @default(now())

  // Relations
  funnel                Funnel    @relation(fields: [funnelId], references: [id], onDelete: Cascade)
  form                  FunnelForm @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@index([funnelId])
  @@index([formId])
  @@index([contactId])
  @@index([createdAt])
}

// Funnel Analytics
model FunnelAnalytics {
  id                    String   @id @default(cuid())
  funnelId              String
  pageId                String?
  eventType             String   // visitor, page_view, button_click, form_conversion, conversion
  visitorId             String?
  sessionId             String?
  ipAddress             String?
  userAgent             String?
  url                   String?
  referrer              String?
  utmSource             String?
  utmMedium             String?
  utmCampaign           String?
  utmTerm               String?
  utmContent            String?
  device                String?  // desktop, tablet, mobile
  browser               String?
  country               String?
  metadata              Json?
  createdAt             DateTime @default(now())

  // Relations
  funnel                Funnel @relation(fields: [funnelId], references: [id], onDelete: Cascade)

  @@index([funnelId])
  @@index([pageId])
  @@index([eventType])
  @@index([visitorId])
  @@index([sessionId])
  @@index([createdAt])
}

// ============= EMAIL & SMS INTEGRATIONS =============
// Provider credentials intentionally remain in server-side environment
// variables. These records only store workspace-scoped communication content,
// delivery state, and provider response metadata.

model EmailTemplate {
  id              String   @id @default(cuid())
  workspaceId     String
  name            String
  description     String?
  subject         String
  htmlBody        String
  textBody        String?
  variables       Json?
  category        String   @default("marketing") // marketing, transactional, automation
  isActive        Boolean  @default(true)
  createdByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  workspace       Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy       User?           @relation("EmailTemplateCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  campaigns       EmailCampaign[]
  messages        OutboundMessage[] @relation("EmailTemplateMessages")

  @@unique([workspaceId, name])
  @@index([workspaceId])
  @@index([workspaceId, isActive])
  @@index([createdByUserId])
  @@index([createdAt])
}

model SmsTemplate {
  id              String   @id @default(cuid())
  workspaceId     String
  name            String
  description     String?
  body            String
  variables       Json?
  category        String   @default("marketing") // marketing, transactional, automation
  isActive        Boolean  @default(true)
  createdByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  workspace       Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy       User?           @relation("SmsTemplateCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  messages        OutboundMessage[] @relation("SmsTemplateMessages")

  @@unique([workspaceId, name])
  @@index([workspaceId])
  @@index([workspaceId, isActive])
  @@index([createdByUserId])
  @@index([createdAt])
}

// A campaign captures a send-ready email snapshot. The optional template link
// preserves provenance while subject/body remain stable if the template later
// changes.
model EmailCampaign {
  id              String   @id @default(cuid())
  workspaceId     String
  templateId      String?
  createdByUserId String?
  name            String
  description     String?
  senderName      String?
  fromEmail       String?
  replyTo         String?
  subject         String
  htmlBody        String
  textBody        String?
  audienceFilter  Json?
  status          String   @default("draft") // draft, scheduled, sending, completed, cancelled, failed
  scheduledFor    DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  cancelledAt     DateTime?
  error           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  workspace       Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  template        EmailTemplate?  @relation(fields: [templateId], references: [id], onDelete: SetNull)
  createdBy       User?           @relation("EmailCampaignCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  messages        OutboundMessage[]

  @@index([workspaceId])
  @@index([workspaceId, status])
  @@index([workspaceId, scheduledFor])
  @@index([templateId])
  @@index([createdByUserId])
  @@index([createdAt])
}

// This is the durable, provider-neutral outbound queue for both email and
// SMS. `channel` is `email` or `sms`; API log views filter this table by
// channel instead of coupling the system to a provider or duplicating queue
// mechanics for every channel.
model OutboundMessage {
  id                  String   @id @default(cuid())
  workspaceId         String
  contactId           String?
  conversationId      String?
  workflowExecutionId String?
  emailTemplateId     String?
  smsTemplateId       String?
  emailCampaignId     String?
  createdByUserId     String?
  channel             String   // email, sms
  recipient           String
  sender              String?
  subject             String?
  body                String
  htmlBody            String?
  status              String   @default("queued") // queued, scheduled, sending, sent, delivered, failed, bounced, undelivered, cancelled
  provider            String?
  providerMessageId   String?
  idempotencyKey      String?
  trackingToken       String?  @unique
  unsubscribeToken    String?  @unique
  scheduledFor        DateTime?
  nextAttemptAt       DateTime?
  lockedAt            DateTime?
  attempts            Int      @default(0)
  maxAttempts         Int      @default(3)
  sentAt              DateTime?
  deliveredAt         DateTime?
  failedAt            DateTime?
  errorCode           String?
  errorMessage        String?
  metadata            Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  workspace           Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contact             Contact?          @relation(fields: [contactId], references: [id], onDelete: SetNull)
  conversation        Conversation?     @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  workflowExecution   WorkflowExecution? @relation(fields: [workflowExecutionId], references: [id], onDelete: SetNull)
  emailTemplate       EmailTemplate?    @relation("EmailTemplateMessages", fields: [emailTemplateId], references: [id], onDelete: SetNull)
  smsTemplate         SmsTemplate?      @relation("SmsTemplateMessages", fields: [smsTemplateId], references: [id], onDelete: SetNull)
  emailCampaign       EmailCampaign?    @relation(fields: [emailCampaignId], references: [id], onDelete: SetNull)
  createdBy           User?             @relation("OutboundMessageCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  logs                OutboundMessageLog[]
  trackingLinks       MessageTrackingLink[]
  trackingEvents      MessageTrackingEvent[]

  @@unique([workspaceId, idempotencyKey])
  @@index([workspaceId])
  @@index([contactId])
  @@index([conversationId])
  @@index([workflowExecutionId])
  @@index([emailTemplateId])
  @@index([smsTemplateId])
  @@index([emailCampaignId])
  @@index([createdByUserId])
  @@index([providerMessageId])
  @@index([workspaceId, channel, status])
  @@index([status, nextAttemptAt])
  @@index([workspaceId, scheduledFor])
  @@index([createdAt])
}

// Append-only operational history for provider requests, delivery webhooks,
// retries, and failures. It is workspace-scoped so support/log queries retain
// tenant isolation without relying on an inferred relationship.
model OutboundMessageLog {
  id                String   @id @default(cuid())
  workspaceId       String
  outboundMessageId String
  level             String   @default("info") // debug, info, warn, error
  event             String   // queued, provider_accepted, delivered, opened, clicked, failed, retry_scheduled
  status            String?
  message           String?
  providerResponse  Json?
  createdAt         DateTime @default(now())

  workspace         Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  outboundMessage   OutboundMessage @relation(fields: [outboundMessageId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([outboundMessageId])
  @@index([workspaceId, createdAt])
  @@index([outboundMessageId, createdAt])
}

// A unique redirect token is allocated for every trackable URL in an email.
// This cleanly supports future click tracking without storing a provider API
// key or implementation-specific data in the browser.
model MessageTrackingLink {
  id                String   @id @default(cuid())
  workspaceId       String
  outboundMessageId String
  destinationUrl    String
  token             String   @unique
  clickCount        Int      @default(0)
  firstClickedAt    DateTime?
  lastClickedAt     DateTime?
  createdAt         DateTime @default(now())

  workspace         Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  outboundMessage   OutboundMessage @relation(fields: [outboundMessageId], references: [id], onDelete: Cascade)
  events            MessageTrackingEvent[]

  @@index([workspaceId])
  @@index([outboundMessageId])
}

// Event rows support an invisible-email-pixel open event as well as tracked
// link clicks. Keep visitor data in `metadata` as a hash/minimized payload,
// rather than storing raw IP addresses by default.
model MessageTrackingEvent {
  id                String   @id @default(cuid())
  workspaceId       String
  outboundMessageId String
  trackingLinkId    String?
  eventType         String   // open, click
  visitorHash       String?
  metadata          Json?
  createdAt         DateTime @default(now())

  workspace         Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  outboundMessage   OutboundMessage     @relation(fields: [outboundMessageId], references: [id], onDelete: Cascade)
  trackingLink      MessageTrackingLink? @relation(fields: [trackingLinkId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([outboundMessageId])
  @@index([trackingLinkId])
  @@index([outboundMessageId, eventType])
  @@index([workspaceId, createdAt])
}

// One active suppression record per normalized address/channel/workspace.
// `contactId` is optional to retain a legal opt-out after a contact is
// deleted, and to accept a provider webhook before a contact is resolved.
model CommunicationOptOut {
  id                String   @id @default(cuid())
  workspaceId       String
  contactId         String?
  channel           String   // email, sms
  address           String
  normalizedAddress String
  reason            String?
  source            String   @default("manual") // manual, unsubscribe_link, inbound_keyword, provider_webhook
  unsubscribedAt    DateTime @default(now())
  resubscribedAt    DateTime?
  metadata          Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  workspace         Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contact           Contact?  @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@unique([workspaceId, channel, normalizedAddress])
  @@index([workspaceId])
  @@index([contactId])
  @@index([workspaceId, channel, resubscribedAt])
  @@index([unsubscribedAt])
}
